# 本应用使用 S3 SigV4 预签名 URL 上传文件，并把上传记录写入 /app/data/uploads.jsonl。
S3_PROFILE_NAME=Default
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# 可选：临时凭证和兼容性配置。
S3_SESSION_TOKEN=
S3_FORCE_PATH_STYLE=false
S3_KEY_PREFIX=
DATA_DIR=/uploads/{{today}}

# 预签名上传链接有效期，单位秒。S3 最大 604800。
SIGNED_URL_TTL_SECONDS=900
